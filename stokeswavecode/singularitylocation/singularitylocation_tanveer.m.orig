F = load('data/recdat_rec10_ep0.9.mat');
recdat = F.recdat;

F = load('data/series_N200_ep0.05.mat');
solseries = F.solseries;
% =====================================

recnum = length(recdat);
sheet = 2;
integral = 0;

for k=1:4
    dgam = (1i)^(k+2);
    integrand = ((recdat(sheet).ff{k}).*(recdat(sheet).zzp{k}))./(recdat(sheet).zz{k});
    integrand = integrand*dgam;
    integral = integral + trapz(recdat(sheet).ff{k}, integrand);
end

coefficient = (1/(2*pi*1i))*integral
%}

